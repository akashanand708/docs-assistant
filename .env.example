# LLM Model (Claude via Amazon Bedrock — uses local AWS credentials)
LLM_MODEL=global.anthropic.claude-sonnet-4-6

# Target website to scrape
DOCS_BASE_URL=https://docs.example.com

# Site name shown in web UI title and system prompt (auto-derived from DOCS_BASE_URL if blank)
# SITE_NAME=MyProduct

# ChromaDB persistence directory (defaults to ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# Collection name in ChromaDB (defaults to "docs")
# COLLECTION_NAME=docs
